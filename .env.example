# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nickel_kg_pass

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b-cloud
# Кол-во чанков в батче при извлечении через Ollama
OLLAMA_EXTRACT_BATCH_SIZE=1
# Таймаут одного запроса к Ollama, сек
OLLAMA_REQUEST_TIMEOUT_SEC=600

# Yandex GPT (optional)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# API
UPLOAD_DIR=data/uploads
OUTPUT_DIR=data/outputs
INGEST_ROOTS=data/inbox,data/uploads
PLATFORM_DB=data/platform.db
AGENT_USE_LLM=false

# Extractor: auto | ollama | yandex
EXTRACTOR_BACKEND=auto
# Таймаут обработки одного чанка на этапе extract, сек
EXTRACT_CHUNK_TIMEOUT_SEC=600
# Размер батча чанков для Yandex-экстрактора
YANDEX_EXTRACT_BATCH_SIZE=8

# SHACL: блокировать загрузку в Neo4j при ошибке валидации
STRICT_SHACL=true

# Глоссарий в пайплайне: false = только exact match (быстрее для больших JSON)
GLOSSARY_USE_BGE=true
# BGE-эмбеддинги для разрешения сущностей (entity resolution); требует sentence-transformers
ENTITY_RESOLUTION_USE_BGE=false

# Опциональные подсистемы поиска (degraded-friendly): включать при готовой инфраструктуре
# Векторный поиск (Qdrant)
SEARCH_USE_VECTORS=false
# Графовый обход (Neo4j)
SEARCH_USE_GRAPH=false
# Индексировать факты в Qdrant при импорте JSON
INDEX_QDRANT_ON_IMPORT=false

# Пользователи и роли — SQLite (PLATFORM_DB) + UI /admin/
# Admin задаётся в .env; остальные роли создаёт admin в /admin/
# Формат: email|имя|api_key (ключ мин. 16 символов)
AUTH_ADMIN=admin@company.ru|Administrator|your-secret-api-key-min-16-chars

# JWT (обмен API-key → Bearer): POST /api/v1/auth/token
JWT_SECRET=change-me-to-random-32-char-secret-key-minimum
JWT_EXPIRE_HOURS=24
API_KEY_TTL_DAYS=90

# HTTPS / ИБ
ENABLE_HSTS=false
TRUST_SSO_HEADERS=false

# Dev/CI: пропустить проверку доступности Ollama в health-check (true в тестах)
SKIP_OLLAMA_HEALTH=false

# LLM-синтез литобзора; backend: yandex | ollama (по умолчанию yandex, если ключи заданы)
LIT_REVIEW_USE_LLM=true
LIT_REVIEW_LLM=yandex

# Dev / production
ENV=development
# CORS (через запятую), например http://localhost:5173,http://localhost:8080
CORS_ORIGINS=
# Отключить Swagger в production
# DISABLE_DOCS=true

# Безопасность и лимиты
MAX_UPLOAD_MB=50
ALLOW_AUTH_SETUP=false
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SEC=60

# Jobs и пайплайн
JOBS_DB=data/jobs.db
PIPELINE_WORKERS=2

# Граф
GRAPH_FETCH_LIMIT=5000
GRAPH_STATS_LIMIT=5000

# Политики платформы (опционально переопределить)
# GLOSSARY_SIM_THRESHOLD=0.72
# FAIR_ONTOLOGY=nickel-kg-v1
# FAIR_LICENSE=internal-rd-use
# FAIR_PROVENANCE=llm_extraction_pipeline

# HTTPS / nginx (production: 80/443; локально без root: 8080/8443)
DOMAIN=
EMAIL=
CERTBOT_STAGING=0
NICKEL_HTTP_PORT=8080
NICKEL_HTTPS_PORT=8443
