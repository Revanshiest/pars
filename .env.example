# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nickel_kg_pass

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b-cloud

# Yandex GPT (optional)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# API
UPLOAD_DIR=data/uploads
OUTPUT_DIR=data/outputs
INGEST_ROOTS=data/inbox,data/uploads
PLATFORM_DB=data/platform.db
AGENT_USE_LLM=false

# Extractor: auto | ollama | yandex
EXTRACTOR_BACKEND=auto

# SHACL: блокировать загрузку в Neo4j при ошибке валидации
STRICT_SHACL=true

# Пользователи и роли хранятся в SQLite (PLATFORM_DB).
# Первый admin: http://localhost:8080/admin/  или  POST /api/v1/auth/setup

# JWT (обмен API-key → Bearer): POST /api/v1/auth/token
JWT_SECRET=change-me-to-random-32-char-secret-key-minimum
JWT_EXPIRE_HOURS=24
API_KEY_TTL_DAYS=90

# HTTPS / ИБ
ENABLE_HSTS=false
TRUST_SSO_HEADERS=false

# LLM-синтез литобзора (Ollama); не требует AGENT_USE_LLM
LIT_REVIEW_USE_LLM=true

# Docker HTTPS: https://localhost:8443 (см. nginx/certs/)
# Docker: OLLAMA_BASE_URL=http://host.docker.internal:11434
